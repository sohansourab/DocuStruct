# DocuStruct environment configuration (example)
# Copy to .env and fill in real values locally. Never commit .env.

# SQLite database path
DOCUSTRUCT_DB_PATH=storage/docustruct.db

# OCR cache directory
OCR_CACHE_DIR=storage/ocr_cache

# Optional: path to local GGUF model if using LocalLLMExtractor
LOCAL_LLM_MODEL_PATH=

# Streamlit server settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
